      "source": [
        "from tensorflow.keras.preprocessing import image\n",
        "\n",
        "def predict_with_tta(model, img_array):\n",
        "    \"\"\"Rata-rata prediksi original + flip horizontal → confidence lebih stabil.\"\"\"\n",
        "    variants = [\n",
        "        img_array,\n",
        "        np.flip(img_array, axis=2),\n",
        "    ]\n",
        "    preds = [model.predict(v, verbose=0)[0] for v in variants]\n",
        "    return np.mean(preds, axis=0)\n",
        "\n",
        "# Ganti path untuk uji gambar lain\n",
        "img_path = 'TrashType_Image_Dataset/glass/glass_033.jpg'\n",
        "CONFIDENCE_THRESHOLD = 0.50\n",
        "USE_TTA = True  # True = lebih stabil untuk metal/plastic\n",
        "\n",
        "img = image.load_img(img_path, target_size=IMG_SIZE)\n",
        "img_array = image.img_to_array(img)\n",
        "img_array = np.expand_dims(img_array, axis=0)\n",
        "img_array = img_array / 255.0\n",
        "\n",
        "if USE_TTA:\n",
        "    predictions = predict_with_tta(model, img_array)\n",
        "else:\n",
        "    predictions = model.predict(img_array, verbose=0)[0]\n",
        "\n",
        "class_names = sorted(train_generator.class_indices.keys())\n",
        "\n",
        "predicted_index = int(np.argmax(predictions))\n",
        "max_confidence = float(predictions[predicted_index])\n",
        "\n",
        "if max_confidence < CONFIDENCE_THRESHOLD:\n",
        "    result_text = 'Jenis Sampah Tidak Dikenali / Kemungkinan Sampah Organik'\n",
        "    status = (\n",
        "        f'(Max prob: {max_confidence * 100:.2f}% < Threshold: {CONFIDENCE_THRESHOLD * 100:.0f}%)'\n",
        "    )\n",
        "else:\n",
        "    result_text = f'Prediksi: {class_names[predicted_index]} ({max_confidence * 100:.2f}%)'\n",
        "    status = f'Dikenali sebagai \"{class_names[predicted_index]}\"'\n",
        "\n",
        "plt.figure(figsize=(6, 6))\n",
        "plt.imshow(img)\n",
        "plt.axis('off')\n",
        "plt.title(result_text, fontsize=14, fontweight='bold')\n",
        "plt.tight_layout()\n",
        "plt.show()\n",
        "\n",
        "print(status)\n",
        "print('\\nProbabilitas semua kelas:')\n",
        "for i, name in enumerate(class_names):\n",
        "    print(f'  {name:10s}: {predictions[i] * 100:6.2f}%')\n",
        "print(f'\\nThreshold : {CONFIDENCE_THRESHOLD * 100:.0f}%')\n",
        "print(f'TTA       : {\"Aktif\" if USE_TTA else \"Nonaktif\"}')\n",
        "print('Model     : CNN dari Nol (practice9V2)')"
      ]
